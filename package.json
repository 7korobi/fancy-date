{
  "name": "fancy-date",
  "version": "0.9.0",
  "description": "架空の暦を扱う",
  "type": "commonjs",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "packageManager": "bun@1.2.16",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/7korobi/fancy-date.git"
  },
  "homepage": "https://github.com/7korobi/fancy-date",
  "bugs": {
    "url": "https://github.com/7korobi/fancy-date/issues"
  },
  "author": "7korobi",
  "license": "MIT",
  "keywords": [
    "calendar",
    "era",
    "date"
  ],
  "tags": [
    "calendar",
    "era",
    "date"
  ],
  "preferGlobal": true,
  "private": false,
  "sideEffects": false,
  "files": [
    "lib/**/*.js",
    "lib/**/*.d.ts"
  ],
  "scripts": {
    "prepublishOnly": "bun run compile",
    "test": "bun run compile && bun run format:check && bun run jest",
    "watch": "jest --watchAll --config config/jest.js --rootDir .",
    "deploy": "bun run test && bun run deploy:npm",
    "deploy:npm": "npm publish",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "jest": "jest --config config/jest.js --rootDir .",
    "jest:update": "jest -u --config config/jest.js --rootDir .",
    "metrics:mean": "bun run compile && node scripts/mean-metrics.js",
    "metrics:naoj": "bun run compile && node scripts/naoj-metrics.js",
    "perf": "bun run perf:core",
    "perf:core": "bun run compile && node scripts/perf.js",
    "compile": "bun run compile:ts",
    "compile:ts": "tsc -p .",
    "type": "tsc -p . --noEmit"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "date-fns": "^4.4.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
