{
  "name": "fancy-date",
  "version": "0.4.1",
  "description": "架空の暦を扱う",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "packageManager": "bun@1.2.16",
  "repository": "git@github.com:7korobi/fancy-date.git",
  "homepage": "https://github.com/7korobi/fancy-date",
  "bugs": {
    "url": "https://github.com/7korobi/fancy-date/issues"
  },
  "author": "7korobi",
  "license": "MIT",
  "keywords": [
    "calendar",
    "era",
    "date"
  ],
  "tags": [
    "calendar",
    "era",
    "date"
  ],
  "preferGlobal": true,
  "private": false,
  "scripts": {
    "test": "bun run compile && bun run format && bun run jest",
    "watch": "jest --watchAll --config config/jest.js --rootDir .",
    "deploy": "bun run test && bun run deploy:npm",
    "deploy:npm": "npm publish",
    "format": "prettier --no-semi --single-quote --print-width 100 --write \"**/*.{ts,tsx,js,jsx,md}\"",
    "format:check": "prettier --no-semi --single-quote --print-width 100 --check \"**/*.{ts,tsx,js,jsx,md}\"",
    "jest": "jest --config config/jest.js --rootDir .",
    "jest:update": "jest -u --config config/jest.js --rootDir .",
    "metrics:mean": "bun run compile && node scripts/mean-metrics.js",
    "metrics:naoj": "bun run compile && node scripts/naoj-metrics.js",
    "compile": "bun run compile:ts",
    "compile:ts": "tsc -p .",
    "type": "tsc -p . --noEmit"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "date-fns": "^4.4.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
